# Copy this file to .env and fill in real values for local development.
# All application variables are prefixed LMS_. See docs/DEVELOPMENT.md for
# where each value comes from.

# --- Application ---------------------------------------------------------
LMS_ENV=development
LMS_PORT=8080
LMS_BASE_URL=http://localhost:8080
# Comma-separated list of allowed CORS origins. Required in staging/production.
# Left empty in development to allow any localhost origin.
LMS_CORS_ALLOWED_ORIGINS=
# Whether the app trusts X-Forwarded-* headers from a reverse proxy.
# Defaults to false in development, true in staging/production.
LMS_TRUST_PROXY=false
# Use human-readable (non-JSON) log output. Defaults to true in development.
LMS_LOG_HUMAN_FORMAT=true

# --- Supabase (local CLI stack: run `supabase start` and copy its output) -
# Postgres connection string printed by `supabase start`.
LMS_DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres
# API URL printed by `supabase start` (Auth + Storage + PostgREST).
LMS_SUPABASE_URL=https://replace-with-your-project.supabase.co
LMS_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
LMS_SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
LMS_SUPABASE_STORAGE_BUCKET=course-media
# JWT secret used to verify Supabase-issued access tokens (HS256).
# Project Settings -> API -> JWT Settings -> JWT Secret.
LMS_SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# --- Redis (Docker Compose service) --------------------------------------
LMS_REDIS_URL=redis://redis:6379

# --- bunny.net (real sandbox/dev credentials, not a stub) ----------------
LMS_BUNNY_API_KEY=replace-with-bunny-sandbox-api-key
LMS_BUNNY_STORAGE_ZONE=replace-with-bunny-sandbox-storage-zone
LMS_BUNNY_CDN_URL=https://replace-with-your-zone.b-cdn.net
# HMAC secret used to verify Bunny Stream's transcoding-complete webhook.
LMS_BUNNY_WEBHOOK_SECRET=replace-with-bunny-webhook-secret

# --- Resend (email) -------------------------------------------------------
LMS_RESEND_API_KEY=replace-with-resend-api-key

# --- Razorpay (scaffolded, unused until Task 6) ---------------------------
LMS_RAZORPAY_KEY_ID=replace-with-razorpay-key-id
LMS_RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret
LMS_RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret
